SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost

# Production-like local setup with native MySQL on port 3307.
DB_ENGINE=mysql
DB_NAME=emoscreen
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3307

# Keep local testing on the built-in dummy payment gateway.
PAYMENT_GATEWAY=dummy

# Optional quick local fallback if you do not want to run MySQL:
# DB_ENGINE=sqlite
# SQLITE_PATH=db.sqlite3

DEFAULT_FROM_EMAIL=noreply@example.com
REPORT_FROM_NAME=EmoScreen Local

PUBLIC_DOCTOR_CODE=PUBLIC0001
PUBLIC_BRAND_NAME=EmoScreen
PUBLIC_PRO_EMAIL=products@example.com
